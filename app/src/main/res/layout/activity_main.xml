<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Grid Size Label -->
    <TextView
        android:id="@+id/grid_size_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:text="Select Grid Size:"
        android:textSize="16sp" />

    <!-- Grid Size Spinner -->
    <Spinner
        android:id="@+id/grid_size_spinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:entries="@array/grid_size_options" />

    <!-- Player Selection Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <CheckBox
            android:id="@+id/two_player_mode_checkbox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2-Player Mode" />

        <CheckBox
            android:id="@+id/ai_mode_checkbox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Play against AI" />
    </LinearLayout>

    <!-- Player Name Inputs Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.2"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/player1_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player 1 Name:"
                android:textSize="16sp" />

            <EditText
                android:id="@+id/player1_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Player 1 Name"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/player2_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Player 2 Name:"
                android:textSize="16sp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/player2_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Enter Player 2 Name"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Color Selection Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.2"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/player1_color_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Player 1 Color:"
                android:textSize="16sp" />

            <Button
                android:id="@+id/player1_color_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/holo_blue_light"
                android:text="Player 1 Color" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/player2_color_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Player 2 Color:"
                android:textSize="16sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/player2_color_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/holo_green_light"
                android:text="Player 2 Color"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Start Game Button -->
        <Button
            android:id="@+id/start_game_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Start Game"
            android:minHeight="48dp"
            android:textSize="16sp"/>

        <!-- Profile Creation Button -->
        <Button
            android:id="@+id/profile_creation_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Create Profile"
            android:minHeight="48dp"
            android:textSize="16sp"/>

        <!-- View Profile Button -->
        <Button
            android:id="@+id/view_profile_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="View Profile"
            android:minHeight="48dp"
            android:textSize="16sp"/>
    </LinearLayout>

    <!-- Additional Player Profile Creation Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/player1_profile_creation_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:text="Create Profile for Player 1"
            android:minHeight="48dp"
            android:textSize="16sp"
            android:visibility="gone"/>

        <Button
            android:id="@+id/player2_profile_creation_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:text="Create Profile for Player 2"
            android:minHeight="48dp"
            android:textSize="16sp"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>